# ============================================================
# LEAD LIFECYCLE TRACKER v2 — CONFIGURACIÓN
# ============================================================
# Copia este archivo a .env.local y llena los valores
# Los valores se obtienen del SETUP_FIREBASE.md

# --- FIREBASE CLIENT (para el frontend) ---
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# --- FIREBASE ADMIN (para el backend / API routes) ---
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# --- BRANDING ---
NEXT_PUBLIC_CLIENT_NAME="Lead Lifecycle Tracker"
NEXT_PUBLIC_THEME_COLOR="#0A84FF"

# --- APP ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
